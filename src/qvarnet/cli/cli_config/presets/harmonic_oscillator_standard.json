{
  "experiment": {
    "name": "harmonic_oscillator_standard",
    "description": "Standard harmonic oscillator benchmark with default MLP",
    "tags": ["continuous", "benchmark", "harmonic_oscillator"]
  },
  "model": {
    "type": "exponential-mlp-fourth-decay",
    "architecture": [2, 10, 1],
    "activation": "tanh"
  },
  "training": {
    "batch_size": 1000,
    "num_epochs": 3000,
    "early_stopping": {
      "patience": 100,
      "min_delta": 1e-6
    }
  },
  "optimizer": {
    "type": "adam",
    "learning_rate": 1e-3
  },
  "sampler": {
    "type": "metropolis_hastings",
    "step_size": 0.5,
    "chain_length": 100,
    "thermalization_steps": 50
  },
  "hamiltonian": {
    "type": "harmonic_oscillator",
    "params": {
      "omega": 1.0,
      "dimensions": 2
    }
  },
  "output": {
    "save_dir": "./results",
    "save_frequency": 100,
    "save_best_only": false
  }
}