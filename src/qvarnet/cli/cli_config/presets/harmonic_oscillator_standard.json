{
  "experiment": {
    "name": "harmonic_oscillator_standard",
    "description": "Standard harmonic oscillator benchmark with default MLP",
    "random_seed": 42
  },
  "model": {
    "type": "exponential-mlp-fourth-decay",
    "architecture": [2, 20, 1],
    "activation": "tanh"
  },
  "training": {
    "batch_size": 200,
    "num_epochs": 3000
  },
  "optimizer": {
    "type": "adam",
    "learning_rate": 1e-3
  },
  "sampler": {
    "type": "metropolis_hastings",
    "step_size": 0.5,
    "chain_length": 100,
    "thermalization_steps": 50
  },
  "hamiltonian": {
    "name": "harmonic-oscillator",
    "params": {
    }
  },
  "output": {
    "save_dir": "./test_harmonic_oscillator"
  }
}